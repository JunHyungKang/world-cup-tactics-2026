{
  "name": "world-cup-tactics-2026",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "node scripts/build-policy-lab.mjs && node scripts/serve-policy-release.mjs",
    "build": "tsc -b && node scripts/build-policy-lab.mjs --output dist",
    "deployment:audit": "node scripts/check-static-deployment.mjs",
    "preview": "node scripts/serve-policy-release.mjs --root dist --port 4173",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test --config playwright.policy.release.config.ts",
    "test:e2e:pre-release": "playwright test --config playwright.policy.release.config.ts",
    "test:e2e:final": "node scripts/run-final-browser.mjs",
    "policy:build": "node scripts/build-policy-lab.mjs",
    "policy:test:e2e": "playwright test --config playwright.policy.config.ts",
    "policy:test:release": "playwright test --config playwright.policy.release.config.ts",
    "policy:verify": "vitest run scripts/policy-lab-spike.test.mjs scripts/policy-lab-release.test.mjs && node scripts/build-policy-lab.mjs",
    "policy:demo": "node scripts/record-policy-lab-demo.mjs",
    "policy:demo:audit": "node scripts/check-policy-lab-demo.mjs",
    "policy:demo:bind": "node scripts/bind-policy-lab-demo-story.mjs",
    "data:audit": "node scripts/check-data-manifest.mjs",
    "copy:audit": "node .agents/skills/korean-copy-qa/scripts/audit-copy.mjs",
    "data:derive": "node scripts/derive-corner-scenarios.mjs",
    "data:reproduce": "vitest run --config vite.raw.config.ts",
    "eligibility:audit": "node scripts/check-eligibility.mjs",
    "eligibility:record-question": "node scripts/record-organizer-question.mjs",
    "user:audit": "node scripts/check-user-study.mjs",
    "planning:audit": "node scripts/check-planning-contract.mjs",
    "planning:capture": "node scripts/capture-policy-planning.mjs",
    "planning:draft": "node scripts/render-planning-draft.mjs",
    "planning:draft:inspect": "node scripts/check-planning-draft.mjs",
    "planning:review": "node scripts/prepare-plan-review.mjs",
    "planning:handoff": "node scripts/prepare-plan-owner-handoff.mjs",
    "demo:audit": "node scripts/check-submission-story.mjs",
    "gallery:render": "node scripts/render-gallery-first-image.mjs",
    "demo:capture": "node scripts/capture-demo-storyboard.mjs",
    "demo:rehearse": "node scripts/record-demo-rehearsal.mjs",
    "demo:rehearsal:audit": "node scripts/check-demo-rehearsal.mjs",
    "demo:narrate": "node scripts/render-demo-narration.mjs",
    "demo:narration:audit": "node scripts/check-demo-narration.mjs",
    "harness:audit": "node scripts/check-harness.mjs",
    "submission:preflight": "node scripts/preflight-submission.mjs",
    "submission:drill": "node scripts/drill-release-build.mjs",
    "submission:build": "node scripts/build-release.mjs",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm deployment:audit && pnpm harness:audit && pnpm data:audit && pnpm copy:audit && pnpm eligibility:audit && pnpm planning:audit && pnpm demo:audit && pnpm user:audit"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
